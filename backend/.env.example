APP_ENV=dev
APP_SECRET=change_this_to_a_32_char_random_string

MONGODB_URI=mongodb://app_user:app_password@mongo:27017
MONGODB_DB=ets_reservations

# JWT — RS256 asymmetric keys (generated at Docker build time)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_this_to_a_strong_random_passphrase

CORS_ALLOW_ORIGIN=http://localhost:3000
